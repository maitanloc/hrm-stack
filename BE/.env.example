APP_NAME=HRM_API
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Ho_Chi_Minh

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=HRM_SYSTEM
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

JWT_SECRET=replace_with_secure_secret
JWT_ISSUER=hrm-system
JWT_TTL=3600
ATTENDANCE_PRECHECK_SECRET=replace_with_strong_attendance_secret

CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_EXPOSE_HEADERS=Content-Type,Authorization
CORS_MAX_AGE=86400

# Mail settings
# MAIL_DRIVER: log | mail | smtp
MAIL_DRIVER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=HRM System
MAIL_REPLY_TO_ADDRESS=no-reply@example.com
MAIL_REPLY_TO_NAME=HRM Support
MAIL_EHLO_DOMAIN=localhost
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_TIMEOUT=15

# Kiosk Face Attendance
KIOSK_AI_ENGINE_URL=http://100.126.50.2:6868
KIOSK_AI_IDENTIFY_THRESHOLD=0.6
KIOSK_SECRET=demo_secret_change_me
