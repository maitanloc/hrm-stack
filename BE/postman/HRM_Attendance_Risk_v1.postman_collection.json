        "body": {
          "mode": "raw",
          "raw": "{\n  \"employee_id\": {{employee_id}},\n  \"otp_code\": \"123456\",\n  \"new_device_id\": \"{{device_id}}\",\n  \"platform\": \"ANDROID\",\n  \"app_version\": \"1.0.0\",\n  \"client_time\": \"2026-04-15T07:58:00+07:00\"\n}"
        },
