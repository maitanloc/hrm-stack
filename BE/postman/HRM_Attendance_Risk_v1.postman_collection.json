            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employee_id\": {{employee_id}},\n  \"precheck_token\": \"{{precheck_token}}\",\n  \"reason\": \"Lệch GPS trong hầm gửi xe, xin duyệt ngoại lệ một lần.\",\n  \"lat\": 10.7772,\n  \"lng\": 106.7001,\n  \"requested_at\": \"2026-04-15T08:05:00+07:00\"\n}"
